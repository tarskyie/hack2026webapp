@page "/register"
@inject ConnectivityService connectivityService

<h3>Register</h3>

<MudTextField @bind-Value="email" Label="Enter E-Mail" Variant="Variant.Outlined" />
<MudTextField @bind-Value="username" Label="Enter Name" Variant="Variant.Outlined" />
<MudTextField @bind-Value="password" Label="Enter Password" Variant="Variant.Outlined" />
<MudButton OnClick="Register_Onclick">Register</MudButton>
@status

@code {
    private string username;
    private string password;
    private string email;

    private string status = string.Empty;

    private async Task Register_Onclick()
    {
        string? response = await connectivityService.Register(email, username, password);
        if (response == null)
        {
            status = "Null";
            return;
        }
        status = response;
        if (response.Substring(0, 7) == "success")
        {
            status = "Аккаунт создан.";
        }
        return;
    }
}
